{
  "name": "express-practice-webapp",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "server": "node server.js",
    "client": "npm --prefix client run dev",
    "dev": "concurrently -n server,client -c blue,green \"npm run server\" \"npm run client\"",
    "build": "npm --prefix client install && npm --prefix client run build",
    "start": "node server.js",
    "postinstall": "npm --prefix client install",
    "test": "jest"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
