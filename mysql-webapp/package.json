{
  "name": "sql-practice",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "build:questions": "node tools/build-questions.js",
    "watch:questions": "node tools/build-questions.js --watch",
    "server": "node server.js",
    "client": "npm --prefix client run dev",
    "dev": "npm run build:questions && concurrently -n questions,server,client -c yellow,blue,green \"npm run watch:questions\" \"npm run server\" \"npm run client\"",
    "build": "npm run build:questions && npm --prefix client install && npm --prefix client run build",
    "prefetch:mysql": "node tools/prefetch-mysql.js",
    "start": "npm run build:questions && node server.js",
    "postinstall": "npm --prefix client install",
    "test": "jest"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "jest": "^29.7.0",
    "mysql-memory-server": "^1.14.1",
    "mysql2": "^3.11.3",
    "supertest": "^7.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
